# WhatsApp Bot Configuration
WHATSAPP_BOT_PHONE=           # The dedicated phone number connected to this bot (for reference only)
SCAN_INTERVAL_MINUTES=30      # How often to scan conversations (default: 30)
SCAN_LOOKBACK_HOURS=24        # How far back to look in conversations (default: 24 hours)

# Monitored Conversations — comma-separated WhatsApp JIDs or contact names
# The bot will ONLY scan these conversations for action items
# Format: 1234567890@s.whatsapp.net for individuals, 123456789-987654321@g.us for groups
MONITORED_CHATS=

# Haley's WhatsApp JID — for sending her notifications
HALEY_WHATSAPP_JID=

# AI Provider Configuration
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=glm-4.7
OPENROUTER_FALLBACK_MODEL=deepseek/deepseek-chat-v3.2
ANTHROPIC_API_KEY=            # Premium fallback only

# Supabase (Project Ops database — direct insert)
SUPABASE_URL=                 # e.g. https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=         # Service role key from Supabase dashboard > Settings > API

# Project Ops Integration (legacy REST — not used with Supabase direct)
PROJECT_OPS_API_URL=https://project-ops-mcp-production.up.railway.app
PROJECT_OPS_API_KEY=

# CRM API Integration (for logging scanned conversations)
CRM_API_URL=                  # The keepintouch-crm Railway URL
CRM_API_KEY=                  # The CRM's API key

# Logging
LOG_LEVEL=info
